{
  "name": "paperbridge",
  "version": "0.0.4",
  "description": "PaperBridge - 科研文献管理与 AI 辅助桌面应用",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:vue\"",
    "dev:server": "node server/index.js",
    "dev:vue": "vite",
    "build:vue": "vite build",
    "electron:dev": "concurrently \"npm run dev:server\" \"npm run dev:vue\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:vue && electron-builder",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/vue-3": "^3.20.0",
    "archiver": "^7.0.1",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "fast-xml-parser": "^5.4.2",
    "https-proxy-agent": "^7.0.6",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.paperbridge.app",
    "productName": "PaperBridge",
    "asar": false,
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "dist/**/*",
      ".env.example",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data/",
        "to": "data/",
        "filter": [
          "!*.db",
          "!*.db-shm",
          "!*.db-wal",
          "!error.log",
          "!images/**",
          "!history/**",
          "!wallet/**"
        ]
      },
      {
        "from": "tools/",
        "to": "tools/"
      },
      {
        "from": "word-addin/",
        "to": "word-addin/"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
